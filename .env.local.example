# OpenAI (chat, classifier, condenser, follow-ups, multimodal PDF parser)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Per-tier model overrides (opcionais). Vazios => todos caem em OPENAI_MODEL
# (back-compat exato). getOpenAIModel(tier) resolve OPENAI_MODEL_<TIER> ->
# OPENAI_MODEL -> gpt-4o-mini. Permite, ex., gpt-4o só no multimodal sem
# afetar a latência do chat nem o custo do roteamento.
OPENAI_MODEL_GENERATION=   # chat + assistentes generate/refine + extractors (qualidade)
OPENAI_MODEL_MULTIMODAL=   # parsing de PDF na ingestão (erro contamina retrieval)
OPENAI_MODEL_ROUTING=      # classify/condense/followups/title (JSON curto — manter barato)

# Voyage AI
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3-large

# Cohere
COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-multilingual-v3.0

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# Langfuse (sub-projeto 7 — pode ficar vazio na Fundação)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Sub-projeto 8: drives env:<value> tag on Langfuse traces.
# Allowed values: local | beta | production | ci
APP_ENV=local

# Dados fiscais (mcp-fiscal-brasil) — serviço REST separado (Docker no Railway).
# Vazio => features fiscais (homologação, lookup de CNPJ, selo fiscal, tool de voz)
# ficam desligadas (fail-soft). Ver docs/product/fiscal-api-contract.md.
FISCAL_API_URL=   # ex.: https://mcp-fiscal.up.railway.app

# Sanções/inidoneidade (CEIS/CNEP) via Portal da Transparência (CGU).
# Token grátis: portaldatransparencia.gov.br/api-de-dados/cadastrar-email
# Vazio => bloco de sanções fica desligado (fail-soft).
PORTAL_TRANSPARENCIA_TOKEN=

# Due diligence reputacional na homologação (busca web da OpenAI). Liga por
# padrão (usa OPENAI_API_KEY); custa por homologação. Setar 'false' desliga.
HOMOLOGACAO_WEBSEARCH=

# Dados públicos de compras (sub-projeto 37 — PNCP, Compras.gov.br, BACEN).
# APIs públicas SEM chave; chamadas direto do Node (sem servidor mcp-brasil nem
# cliente MCP). Ligadas por padrão. GOVDATA_ENABLED=false é o kill-switch.
# As 3 URLs têm default público — só preencha pra apontar pra um proxy.
# Ver docs/product/govdata-api-contract.md.
GOVDATA_ENABLED=          # default true; 'false' desliga preço de referência, catálogo, indicadores
PNCP_API_URL=            # default https://pncp.gov.br/api/consulta
COMPRAS_API_URL=         # default https://dadosabertos.compras.gov.br
BACEN_API_URL=           # default https://api.bcb.gov.br/dados
